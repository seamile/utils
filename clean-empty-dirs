#!/bin/bash

RED="\033[1;31m"
ORANGE="\033[0;33m"
GREEN="\033[0;32m"
END="\033[0m"

AUTO_YES=false
TARGETS=()

for arg in "$@"; do
    if [[ "$arg" == "-y" ]]; then
        AUTO_YES=true
    else
        TARGETS+=("$arg")
    fi
done

if [[ ${#TARGETS[@]} == 0 ]]; then
    TARGETS=(".")
fi

# 删除 .DS_Store 文件
find "${TARGETS[@]}" -type f -name .DS_Store -delete

# 收集空目录
EMPTY_DIRS=()
while IFS= read -r d; do
    if [[ "$d" != "." && "$d" != "./" ]]; then
        EMPTY_DIRS+=("$d")
    fi
done < <(find "${TARGETS[@]}" -type d -empty)

num=${#EMPTY_DIRS[@]}

if [[ $num == 0 ]]; then
    printf "Not found any empty directories.\n"
    exit 0
fi

for i in "${!EMPTY_DIRS[@]}"; do
    idx=$((i + 1))
    printf "$ORANGE%2d  ${EMPTY_DIRS[$i]}$END\n" $idx
done

echo

if [[ "$AUTO_YES" == false ]]; then
    printf "${RED}Are you sure to delete these directories?$END (y/n) "
    read -n 1 DEL
    echo
    if [[ "$DEL" != "y" && "$DEL" != "Y" ]]; then
        printf "Cancel\n"
        exit 0
    fi
fi

printf "Deleting...\n"
find "${TARGETS[@]}" -type d -empty -delete
printf "Deleted $num empty directories.\n"
